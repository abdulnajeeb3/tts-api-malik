# TTS API — example environment file. Copy to .env and fill in.

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ---- Auth ----
# Comma-separated list of valid API keys for X-API-Key header.
API_KEYS=dev-local-key-change-me

# ---- Models ----
# Which models to load at startup. In the separate-runtime Docker setup this is
# overridden per service, so the shared default stays conservative.
ENABLED_MODELS=qwen3-tts

# HuggingFace cache dir (mounted as volume in docker-compose)
HF_HOME=/models_cache/huggingface
TRANSFORMERS_CACHE=/models_cache/huggingface

# Qwen3-TTS
QWEN_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_DEVICE=cuda:0
QWEN_SPEAKER=Aiden
QWEN_LANGUAGE=English
QWEN_INSTRUCT=Professional and friendly tone.
QWEN_DTYPE=bfloat16
QWEN_ATTN_IMPLEMENTATION=flash_attention_2

# Chatterbox
CHATTERBOX_MODEL_ID=ResembleAI/chatterbox
CHATTERBOX_DEVICE=cuda:0
CHATTERBOX_MODE=english
CHATTERBOX_AUDIO_PROMPT=
CHATTERBOX_LANGUAGE_ID=en

# ---- Audio defaults ----
DEFAULT_SAMPLE_RATE=24000
DEFAULT_STREAM_FORMAT=pcm
DEFAULT_REST_FORMAT=mp3

# ---- Concurrency ----
# Max concurrent inference workers (thread pool size).
INFERENCE_WORKERS=8
MAX_CONCURRENT_STREAMS=10

# ---- Dev ----
# Set to 1 to use mock models (no GPU needed) for local dev/testing.
USE_MOCK_MODELS=0
